{
  "name": "orthanc/server",
  "authors": [
    {
      "name": "kfarkasHU",
      "email": "sohamar@farkask.eu"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.8",
    "vimeo/psalm": "^5.13"
  },
  "scripts": {
    "gha:lint": "vendor/bin/phpcs --standard=phpcs.xml --runtime-set ignore_warnings_on_exit 1 src/",
    "gha:sca": "vendor/bin/psalm --show-info=true --show-snippet=true",
    "gha:syntax": "find src -name '*.php' -exec php -l {} \\;",
    "gha:test:unit": "phpunit --test-suffix spec.php ."
  },
  "config": {
    "platform": {
      "php": "8.1.0"
    }
  }
}
